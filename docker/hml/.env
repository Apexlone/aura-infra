# ==============================================================================
# AURASKILL - INFRASTRUCTURE ENVIRONMENT VARIABLES (HOMOLOGATION)
# ==============================================================================
ENV_NAME=hml
COMPOSE_PROJECT_NAME=auraskill_${ENV_NAME}_stack

# --- NETWORK & HOSTS ---
AURASKILL_HOST_IP=172.18.203.72
AURA_API_PATH=/home/guiassys/actions-runner/_work/aura-api/aura-api
AURA_FRONT_PATH=/home/guiassys/actions-runner/_work/aura-front/aura-front
AURA_EUREKA_PATH=/home/guiassys/actions-runner/_work/aura-eureka/aura-eureka
AURA_GATEWAY_PATH=/home/guiassys/actions-runner/_work/aura-gateway/aura-gateway

# --- PATHS & VOLUMES (WSL / Local Linux) ---
DB_APP_VOL_PATH=/home/guiassys/docker-data/aura-infra/${ENV_NAME}-app-db
DB_KC_VOL_PATH=/home/guiassys/docker-data/aura-infra/${ENV_NAME}-keycloak-db
REDIS_VOL_PATH=/home/guiassys/docker-data/aura-infra/${ENV_NAME}-redis-data
DB_SONAR_VOL_PATH=/home/guiassys/docker-data/aura-infra/${ENV_NAME}-sonar-db
MINIO_VOL_PATH=/home/guiassys/docker-data/aura-infra/${ENV_NAME}-minio-data

# --- KEYCLOAK LOCAL DATABASE ---
KC_DB_URL=jdbc:postgresql://auraskill-db-keycloak-${ENV_NAME}:5432/keycloak_db
KC_DB_USER=keycloak_user
KC_DB_NAME=keycloak_db
KC_DB_PORT=5433
KC_DB_INTERNAL_PORT=5432

# --- KEYCLOAK SERVICE ---
KC_ADMIN_USER=admin
KC_PORT=8080
KC_INTERNAL_PORT=8080
KC_HOSTNAME_URL=http://${AURASKILL_HOST_IP}:8080

# --- APPLICATION DATABASE ---
APP_DB_USER=guiassys
APP_DB_NAME=auraskill
APP_DB_PORT=5432
APP_DB_INTERNAL_PORT=5432

# --- SONARQUBE DATABASE ---
SONAR_DB_USER=sonarqube_user
SONAR_DB_NAME=sonarqube_db
SONAR_DB_PORT=5434
SONAR_DB_INTERNAL_PORT=5432

# --- SONARQUBE SERVICE ---
SONAR_PORT=9300
SONAR_INTERNAL_PORT=9000

# --- REDIS CACHE SERVER ---
REDIS_HOST=auraskill-redis-${ENV_NAME}
REDIS_PORT=6379
REDIS_INTERNAL_PORT=6379
REDIS_DB=0
REDIS_TIMEOUT=60000
REDIS_MAX_RETRIES=3

# --- MINIO OBJECT STORAGE (S3 COMPATIBLE) ---
MINIO_PORT=9001
MINIO_INTERNAL_PORT=9000
MINIO_CONSOLE_PORT=9002
MINIO_CONSOLE_INTERNAL_PORT=9001
MINIO_ROOT_USER=minioadmin
MINIO_DEFAULT_BUCKETS=auraskill-bucket

# --- FRONTEND (NEXT.JS) ---
FRONT_PORT=3000
FRONT_INTERNAL_PORT=3000
KEYCLOAK_CLIENT_ID=auraskill-frontend
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8081

# --- BACKEND (SPRING BOOT) ---
API_PORT=8081
API_INTERNAL_PORT=8081
SPRING_APPLICATION_NAME=auraskill-api
SPRING_JPA_HIBERNATE_DDL_AUTO=validate
SPRING_JPA_OPEN_IN_VIEW=false
SPRING_JPA_SHOW_SQL=true
SPRING_JPA_PROPERTIES_HIBERNATE_FORMAT_SQL=true
SPRING_FLYWAY_ENABLED=true
KEYCLOAK_ISSUER_URI=http://${AURASKILL_HOST_IP}:8080/realms/auraskill

# --- EUREKA ---
EUREKA_APP_NAME=aura-eureka
EUREKA_PORT=8761
EUREKA_INTERNAL_PORT=8761
EUREKA_HEALTH_ENDPOINT=/actuator/health

# --- GATEWAY ---
GATEWAY_PORT=8085
GATEWAY_INTERNAL_PORT=8085
