# ==============================================================================
# AURASKILL - INFRASTRUCTURE ENVIRONMENT VARIABLES (TEMPLATE)
# ==============================================================================
# Instruções: Copie este arquivo para .env e preencha os valores reais.

COMPOSE_PROJECT_NAME=auraskill_stack

# --- KEYCLOAK EXTERNAL DB (SUPABASE) ---
# O host geralmente segue o padrão: [id].pooler.supabase.com:5432/postgres
KC_DB_URL_SUPABASE=jdbc:postgresql://<SEU_HOST_SUPABASE>:5432/postgres?sslmode=require
KC_DB_USER_SUPABASE=postgres.<SEU_ID_PROJETO>
KC_DB_PASSWORD_SUPABASE=<SUA_SENHA_BANCO>
KC_ADMIN_USER=admin
KC_ADMIN_PASSWORD=admin
KC_PORT=8080

# --- POSTGRES (Aplicação Java) ---
APP_DB_USER=auraskill_user
APP_DB_PASSWORD=changeit
APP_DB_NAME=auraskill
APP_DB_PORT=5432